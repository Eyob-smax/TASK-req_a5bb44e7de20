APP_NAME=CampusLearn
APP_ENV=local
# Generate with: php artisan key:generate --show  (run inside the container or with Laravel installed locally)
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
APP_LOCALE=en

LOG_CHANNEL=stderr
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=campuslearn
DB_USERNAME=campuslearn
# Password for the campuslearn DB user — must match MYSQL_ROOT_PASSWORD-derived grants
DB_PASSWORD=
# Root password for the mysql container (required by the mysql image)
MYSQL_ROOT_PASSWORD=

QUEUE_CONNECTION=database
DB_QUEUE_TABLE=jobs
DB_QUEUE_RETRY_AFTER=90

# Session token lifetime in minutes
SANCTUM_TOKEN_EXPIRY=60

# Local encryption keys — generate random 32-byte hex values; NEVER commit real values
# Example (Linux/Mac): openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=
DIAGNOSTIC_ENCRYPTION_KEY=
